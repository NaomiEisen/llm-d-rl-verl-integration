# Integration image for llm-d RL verl — vLLM 0.18.x build.
#
# Differences from Dockerfile.llmd-vllm-v18-dev:
#   - No local verl source COPY; verl is installed from a pinned git commit.
#   - No Go build stage; EPP and sidecar binaries are copied from their
#     published container images using multi-stage COPY --from.
#
# Build (from any directory — no local source context required):
#   podman build \
#     -f verl/docker/Dockerfile.verl-vllm018-llm-d-integration \
#     --platform linux/amd64 \
#     --build-arg VERL_COMMIT=<commit-sha> \
#     -t <your-registry>/verl:vllm018-llm-d-integration \
#     .
#
ARG BASE_IMAGE=verlai/verl:vllm018.dev1

# Binary source images — must match the target platform so the executables run on the node.
# TARGETPLATFORM is set automatically by `docker buildx build --platform <arch>`.
FROM --platform=${TARGETPLATFORM} ghcr.io/llm-d/llm-d-router-endpoint-picker-dev:main AS epp-source
# TODO: switch to official once pushed
FROM --platform=${TARGETPLATFORM} ghcr.io/naomieisen/llm-d-router-sidecar:pr-1458 AS sidecar-source 
FROM --platform=${TARGETPLATFORM} docker.io/envoyproxy/envoy:distroless-v1.33.2 AS envoy-source

FROM ${BASE_IMAGE}

# --- veRL from pinned commit ---
ARG VERL_COMMIT=334d9f8b03816382cbd72e898bc8ae04efca6fbe
RUN git clone https://github.com/volcengine/verl.git /opt/verl && \
    cd /opt/verl && git checkout ${VERL_COMMIT} && \
    pip install --no-deps -e .

# --- cupy / numpy compatibility ---
# The base image ships cupy 14.x (requires numpy>=2.0) but veRL pins numpy<2.0.0.
# Downgrade cupy to 13.x which supports numpy 1.x.
RUN pip install "cupy-cuda12x<14"

# --- NIXL for vLLM NixlConnector (P/D KV transfer) ---
# verl base images do not ship kv_connectors deps.
# Without this, vLLM fails at engine init with: RuntimeError: NIXL is not available
RUN pip install "nixl==0.10.1" "nixl-cu12==0.10.1" && \
    python3 -c "from nixl._api import nixl_agent; print('NIXL OK')"

# --- Llmd binaries ---
COPY --from=epp-source /app/epp /usr/local/bin/epp
COPY --from=sidecar-source /app/pd-sidecar /usr/local/bin/llm-d-routing-sidecar
COPY --from=envoy-source /usr/local/bin/envoy /usr/local/bin/envoy


# --- Vllm fixes ---
# ---  Fix vLLM disagg/serving.py — forward kv_transfer_params to engine ---
# /inference/v1/generate receives kv_transfer_params (do_remote_decode=true) from the
# llm-d sidecar but disagg/serving.py never copies it into sampling_params.extra_args.
# The NixlConnector reads it from sampling_params.extra_args.get("kv_transfer_params"),
# so without this patch it always sees None and returns kv_transfer_params=null, meaning
# no KV cache is transferred between prefill and decode.
# Root cause confirmed in vLLM debug logs (NIXLConnector request_finished kv_transfer_params=None).
# This path is specific to /inference/v1/generate (token-in token-out); /v1/chat/completions
# already forwards kv_transfer_params correctly, which is why other deployments work.
RUN sed -i \
    's/        result_generator = self\.engine_client\.generate(/        if request.kv_transfer_params:\n            if sampling_params.extra_args is None:\n                sampling_params.extra_args = {}\n            sampling_params.extra_args["kv_transfer_params"] = request.kv_transfer_params\n\n        result_generator = self.engine_client.generate(/' \
    /usr/local/lib/python3.12/dist-packages/vllm/entrypoints/serve/disagg/serving.py

# --- Fix vLLM sleep() — drain NIXL notifications before reset_prefix_cache ---
# When EngineCore goes idle after generation, NIXL "read complete" notifications may
# still be in the worker queue (decode confirmed receipt but prefill hasn't processed it).
# reset_prefix_cache() then fails: "blocks not freed yet — remote KV transfer not supported".
# Fix: add drain_kv_connector() that polls get_finished() without a forward pass, called
# from _reset_caches() before reset_prefix_cache(). Pending PR: vllm-project/vllm#42644.

# scheduler.py: add has_pending_connector_sends() + free_finished_connector_sends()
RUN sed -i \
    's/        return len(self\.finished_req_ids) > 0/        return len(self.finished_req_ids) > 0\n\n    def has_pending_connector_sends(self):\n        return self.connector is not None and bool(self.requests)\n\n    def free_finished_connector_sends(self, finished_sending):\n        for req_id in finished_sending:\n            if req_id in self.requests:\n                self._free_blocks(self.requests[req_id])/' \
    /usr/local/lib/python3.12/dist-packages/vllm/v1/core/sched/scheduler.py

# gpu_worker.py: add drain_kv_connector()
RUN sed -i \
    's/        self\.model_runner\._dummy_run(1, uniform_decode=True)/        self.model_runner._dummy_run(1, uniform_decode=True)\n\n    def drain_kv_connector(self):\n        if not has_kv_transfer_group():\n            return set()\n        connector = get_kv_transfer_group()\n        finished_sending, _ = connector.get_finished(set())\n        return finished_sending/' \
    /usr/local/lib/python3.12/dist-packages/vllm/v1/worker/gpu_worker.py

# abstract.py: add drain_kv_connector() RPC
RUN sed -i \
    's/        self\.collective_rpc("execute_dummy_batch")/        self.collective_rpc("execute_dummy_batch")\n\n    def drain_kv_connector(self):\n        output = self.collective_rpc("drain_kv_connector")\n        result = set()\n        for s in output:\n            result.update(s)\n        return result/' \
    /usr/local/lib/python3.12/dist-packages/vllm/v1/executor/abstract.py

# core.py: add EngineCore.drain_kv_connector() after execute_dummy_batch
RUN sed -i \
    's/        self\.model_executor\.execute_dummy_batch()/        self.model_executor.execute_dummy_batch()\n\n    def drain_kv_connector(self):\n        if not self.scheduler.has_pending_connector_sends():\n            return\n        finished_sending = self.model_executor.drain_kv_connector()\n        self.scheduler.free_finished_connector_sends(finished_sending)/' \
    /usr/local/lib/python3.12/dist-packages/vllm/v1/engine/core.py

# core.py: call drain_kv_connector() in _reset_caches before reset_prefix_cache
RUN sed -i \
    's/        self\.reset_prefix_cache(reset_running_requests=reset_running_requests)/        self.drain_kv_connector()\n        self.reset_prefix_cache(reset_running_requests=reset_running_requests)/' \
    /usr/local/lib/python3.12/dist-packages/vllm/v1/engine/core.py
